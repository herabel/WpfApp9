<Page x:Class="WpfApp9.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfApp9"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1600"
      Title="Dashboard" FontSize="26">

    <Grid Background="AliceBlue">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width=".3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height=".3*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="1">
            <Button x:Name="AddBtn" Margin="0,10,0,0" Content="Добавить" Click="AddBtn_Click"/>
            <Button Margin="0,10,0,0" Content="Кнопка" Click="AddBtn_Click"/>
            <Button Margin="0,10,0,0" Content="Кнопка" Click="AddBtn_Click"/>
            <Button Margin="0,10,0,0" Content="Кнопка" Click="AddBtn_Click"/>
        </StackPanel>
        <ListBox HorizontalContentAlignment="Stretch" Background="AntiqueWhite" Grid.Column="1" Grid.Row="1" d:ItemsSource="{d:SampleData ItemCount=50}" Name="ListBox" VirtualizingPanel.ScrollUnit="Pixel">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="30" Background="MintCream" Height="200" Margin="0,5,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width=".2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width=".2*"/>
                            </Grid.ColumnDefinitions>
                            <Image Stretch="Uniform" Source="{Binding DisplayImage}"/>
                            <TextBlock Grid.Column="1">
                                <Run Text="{Binding ProductName}"/> | <Run Text="{Binding Category}"/>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Column="1" HorizontalAlignment="Left">
            <TextBlock Text="Основная страница"/>
            <TextBlock Text="Поиск:"/>
            <TextBox Name="SearchTB" Width="400" TextChanged="SearchTB_TextChanged"/>
            <ComboBox Name="FilterCB" Margin="0,10,0,0" SelectionChanged="FilterCB_SelectionChanged">
                <ComboBoxItem Content="По возрастанию цены"/>
                <ComboBoxItem Content="По убыванию цены"/>
            </ComboBox>
        </StackPanel>
    </Grid>
</Page>
